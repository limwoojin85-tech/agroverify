  "autostart_default": false,
  "autostart_modes": [],

  "tags": ["verify", "agro", "innong-companion"],

  "min_python": "3.11",

  "notes": {
    "purpose": "innong 본체와 분리된 검수 전용 GUI. agro_data_v2/daily/*.db 만 read.",
    "granularity": "(시장, 법인) 단위 비교 (사용자 요청 v0.3)"
